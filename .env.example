# Copy to .env and adjust for your deployment. Used by examples/node-server.js.

# Port the example server listens on.
PORT=3000

# SQLite database path. Use :memory: for an ephemeral database.
WHISPER_DB=./whisper.db

# Number of reverse proxies in front of the app. Leave unset (or 0) when the app
# is exposed directly. Set to 1 behind a single proxy, etc. This must be correct
# or rate limiting can be bypassed via a spoofed X-Forwarded-For header.
# TRUST_PROXY=1
